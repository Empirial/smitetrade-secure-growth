rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isAdmin() {
      return hasRole('admin');
    }
    
    function isDriver() {
      return hasRole('driver');
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read and write their own profile
      allow read, write: if request.auth.uid == userId;
      // Admin can read and write all users
      allow read, write: if isAdmin();
      // Owner can read staff (drivers/cashiers/etc) - Simplified to read all for now
      allow read: if isOwner(); 
    }

    // --- Products Collection ---
    match /products/{productId} {
      // Anyone signed in can read products (to shop)
      allow read: if isSignedIn();
      // Only Owner and Admin can manage inventory
      allow write: if isOwner() || isAdmin();
      // Cashiers might need to update stock (future), but for now Owner/Admin
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Users can read their own orders
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'guest');
      
      // Owner/Admin/Cashier/Driver can read all orders (simplified for dashboard access)
      allow read: if isOwner() || isAdmin() || hasRole('cashier') || isDriver();

      // Customers can create orders
      allow create: if isSignedIn();
      
      // Updates:
      // - Owner/Admin/Cashier can update any order
      // - Driver can update status if assigned to them (or claiming it)
      allow update: if isOwner() || isAdmin() || hasRole('cashier') || (isDriver() && (resource.data.driverId == request.auth.uid || request.resource.data.driverId == request.auth.uid));
    }
  }
}
