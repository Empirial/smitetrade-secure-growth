rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isOwner() {
      return hasRole('owner');
    }

    function isAdmin() {
      return hasRole('admin');
    }
    
    function isDriver() {
      return hasRole('driver');
    }

    // --- Validation Functions ---
    function isValidOrder() {
      let data = request.resource.data;
      return data.total is number && 
             data.total >= 0 &&
             data.items is list &&
             data.items.size() > 0 &&
             data.status in ['Pending', 'Paid', 'Ready', 'Out for Delivery', 'Delivered', 'Cancelled'];
    }

    function isValidProduct() {
      let data = request.resource.data;
      return data.name is string &&
             data.price is number &&
             data.price >= 0 &&
             data.stock is number;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read, write: if isAdmin();
      allow read: if isOwner(); 
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if (isOwner() || isAdmin()) && isValidProduct();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'guest');
      allow read: if isOwner() || isAdmin() || hasRole('cashier') || isDriver();

      allow create: if isSignedIn() && isValidOrder();
      
      allow update: if isOwner() || isAdmin() || hasRole('cashier') || (isDriver() && (resource.data.driverId == request.auth.uid || request.resource.data.driverId == request.auth.uid));
    }
  }
}
